{
    "manifest_version": 3,
    "name": "SOCI4L Donate (Fuji Testnet)",
    "version": "1.0.1",
    "description": "SOCI4L Donate extension — Fuji Testnet build for Avalanche Build Games evaluation. Detects verified SOCI4L profiles on X (Twitter) and enables direct testnet AVAX donations.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "SOCI4L Donate"
    },
    "content_scripts": [
        {
            "matches": [
                "https://twitter.com/*",
                "https://x.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "https://twitter.com/*",
        "https://x.com/*"
    ]
}