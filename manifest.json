{
    "manifest_version": 3,
    "name": "SOCI4L Connector",
    "version": "1.0",
    "description": "Connects X.com profiles to SOCI4L Web3 identities.",
    "icons": {
        "16": "icons/icon.svg",
        "48": "icons/icon.svg",
        "128": "icons/icon.svg"
    },
    "content_scripts": [
        {
            "matches": [
                "https://twitter.com/*",
                "https://x.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_end"
        }
    ],
    "host_permissions": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://soci4l.net/*",
        "http://localhost:3000/*"
    ]
}